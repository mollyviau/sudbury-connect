# Copy to .env.local for local dev (never commit .env.local).
# On Vercel, set the same names in Project → Settings → Environment Variables.

NVIDIA_API_KEY=your_nvidia_key_here
VALSEA_API_KEY=your_valsea_key_here

# Optional — only if you use Apify scripts locally
# APIFY_API_KEY=your_apify_key_here

# Optional — defaults to /api/overpass (proxied to overpass-api.de)
# VITE_OVERPASS_URL=https://overpass-api.de/api/interpreter
